<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <Button
        android:id="@+id/btnAddAdvert"
        android:layout_width="288dp"
        android:layout_height="65dp"
        android:layout_marginStart="61dp"
        android:layout_marginTop="273dp"
        android:layout_marginEnd="62dp"
        android:layout_marginBottom="81dp"
        android:text="Create a New Advert"
        app:layout_constraintBottom_toTopOf="@+id/btnShowItems"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnShowItems"
        android:layout_width="288dp"
        android:layout_height="65dp"
        android:layout_marginStart="61dp"
        android:layout_marginTop="81dp"
        android:layout_marginEnd="62dp"
        android:layout_marginBottom="247dp"
        android:text="Show All Lost and Found Items"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAddAdvert" />

</androidx.constraintlayout.widget.ConstraintLayout>